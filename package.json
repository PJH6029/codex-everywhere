{
  "name": "codex-everywhere",
  "version": "0.1.0",
  "description": "Run Codex in tmux with OMX-style Discord notifications and two-way replies.",
  "type": "module",
  "bin": {
    "codex-everywhere": "bin/codex-everywhere.js"
  },
  "scripts": {
    "start": "node bin/codex-everywhere.js",
    "check": "node --check src/*.js && node --check bin/codex-everywhere.js"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "codex",
    "tmux",
    "discord",
    "notifications",
    "agent"
  ],
  "license": "MIT"
}
